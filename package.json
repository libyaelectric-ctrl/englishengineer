{
  "name": "engvox-frontend",
  "private": true,
  "version": "4.0.1",
  "author": "Özcan ERENSAYIN",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "tsc --noEmit && vite build --configLoader runner",
    "clean": "node -e \"const fs=require('fs'); ['dist','.vite','.npm-cache'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\"",
    "test": "vitest run --configLoader runner --reporter dot --exclude src/e2e/** --exclude .mimocode/**",
    "test:watch": "vitest --configLoader runner",
    "test:coverage": "vitest run --coverage --configLoader runner",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "depcruise": "depcruise src backend --config .dependency-cruiser.mjs",
    "depcruise:graph": "depcruise src backend --config .dependency-cruiser.mjs --output-type dot | dot -T svg > dependency-graph.svg",
    "e2e": "vitest run src/e2e --configLoader runner",
    "e2e:browser": "playwright test",
    "backend:install": "npm --prefix backend ci",
    "backend:test": "npm --prefix backend test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "verify:release": "node scripts/verify-release.mjs",
    "verify:rls": "node scripts/verify-supabase-rls.mjs",
    "import:grammar": "node scripts/import-grammar-database.mjs",
    "import:vocabulary": "node scripts/import-vocabulary-database.mjs",
    "verify:grammar": "node scripts/verify-grammar-database.mjs",
    "verify:vocabulary": "node scripts/verify-vocabulary-database.mjs",
    "verify:learning-data": "node scripts/verify-learning-data.mjs",
    "content:validate": "node scripts/validate-content.mjs",
    "verify:test-exit": "node scripts/run-with-timeout.mjs 90000 run test",
    "verify:build-exit": "node scripts/run-with-timeout.mjs 120000 run build",
    "verify:quality-exit": "node scripts/run-with-timeout.mjs 240000 run quality:gate",
    "kademe8:verify": "node scripts/prc-kademe-8-live-verify.mjs",
    "kademe8:check": "node scripts/prc-kademe-8-live-verify.mjs --env-check",
    "quality:gate": "node scripts/quality-gate.mjs",
    "quality:gate:browser": "npm run quality:gate && npm run e2e:browser",
    "e2e:browser:install": "playwright install chromium",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen-audio": "ts-node src/tools/generate-missing-audio.ts",
    "test:load": "k6 run scripts/performance/load-test.k6.js",
    "test:lighthouse": "lighthouse https://englishengineer.vercel.app --output html --output-path ./docs/lighthouse-report.html",
    "test:duplication": "jscpd --min-lines 5 --min-tokens 50 --reporters console",
    "analyze": "ANALYZE=true npm run build",
    "check:licenses": "license-checker --production --csv --out licenses.csv",
    "check:licenses:reject": "license-checker --production --failOn 'GPL-3.0;AGPL-3.0'"
  },
  "dependencies": {
    "@sentry/react": "^8.0.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-error-boundary": "^6.1.2",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.18.0",
    "react-virtuoso": "^4.18.10",
    "tailwind-merge": "^3.6.0",
    "web-vitals": "^5.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.9",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "fflate": "^0.8.3",
    "ffmpeg-static": "^5.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "globals": "^15.0.0",
    "google-tts-api": "^2.0.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^17.0.8",
    "node-fetch": "^3.3.2",
    "prettier": "^3.0.0",
    "read-excel-file": "^6.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^8.6.14",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.1",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "ffmpeg-static@5.3.0": true
  }
}
