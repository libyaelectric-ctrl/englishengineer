{
  "name": "engvox-frontend",
  "private": true,
  "version": "4.0.1",
  "author": "Özcan ERENSAYIN",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:all": "concurrently -n \"frontend,backend\" -c \"blue,green\" \"npm run dev\" \"npm --prefix backend run dev\"",
    "build": "tsc --noEmit && vite build --configLoader runner",
    "clean": "node -e \"const fs=require('fs'); ['dist','.vite','.npm-cache'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\"",
    "test": "vitest run --configLoader runner --reporter dot",
    "test:watch": "vitest --configLoader runner",
    "test:coverage": "vitest run --coverage --configLoader runner",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "e2e": "vitest run src/e2e --configLoader runner",
    "e2e:browser": "playwright test",
    "e2e:browser:install": "playwright install chromium",
    "backend:install": "npm --prefix backend ci",
    "backend:test": "npm --prefix backend test",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@sentry/react": "^8.0.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-error-boundary": "^6.1.2",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.18.0",
    "react-virtuoso": "^4.18.10",
    "tailwind-merge": "^3.6.0",
    "web-vitals": "^5.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^15.0.0",
    "jsdom": "^29.1.1",
    "node-fetch": "^3.3.2",
    "prettier": "^3.0.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "axios": "^1.7.9"
  }
}
