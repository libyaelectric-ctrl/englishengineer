{
  "redirects": [
    {
      "source": "/learning",
      "destination": "/learning-plan",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api|assets|brand|_next|favicon.ico|robots.txt).*)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "englishengineer"
      }
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/agentic/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "services": {
    "englishengineer": {
      "root": "backend",
      "entrypoint": "src/app.ts"
    }
  }
}
