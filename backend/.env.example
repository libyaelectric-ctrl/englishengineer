PORT=8787
APP_ORIGIN=http://localhost:5173
NODE_ENV=development
APP_VERSION=4.0.1

# Protected AI and billing routes. Dev bypass must be enabled explicitly.
ENGINEEROS_INTERNAL_API_SECRET=
ALLOW_INSECURE_DEV_AUTH=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Local/dev/test default to memory. Production defaults to Upstash and blocks
# startup when the external store is missing.
RATE_LIMIT_STORE=memory
RATE_LIMIT_STORE_TIMEOUT_MS=3000
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Emergency exception only; never enable silently in production.
ALLOW_IN_MEMORY_RATE_LIMIT_IN_PRODUCTION=false

# AI runs in explicit mock mode unless a supported provider and key are set.
AI_PROVIDER=mock
AI_MODEL=
AI_TIMEOUT_MS=20000
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=30
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Stripe values must be test-mode values during local verification.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PROJECT_MONTHLY=
STRIPE_PRICE_MAX_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_EVENT_CACHE_TTL_MS=86400000
STRIPE_EVENT_CACHE_MAX=5000
ALLOW_MEMORY_BILLING_REPOSITORY=false
BILLING_REPOSITORY=memory

# The service role key is backend-only and must never use the VITE_ prefix.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional vocabulary translation. Dictionary definitions use dictionaryapi.dev.
VOCABULARY_LOOKUP_TIMEOUT_MS=8000
VOCABULARY_LOOKUP_RATE_LIMIT_MAX=60
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
MYMEMORY_ENABLED=false
