PORT=8080
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
APP_VERSION=4.0.1

# AI - Google Gemini
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
AI_MODEL=gemini-2.0-flash
AI_TIMEOUT_MS=20000
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=30

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
BILLING_REPOSITORY=supabase

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PROJECT_MONTHLY=price_xxx
STRIPE_PRICE_MAX_MONTHLY=price_xxx
STRIPE_EVENT_CACHE_TTL_MS=86400000
STRIPE_EVENT_CACHE_MAX=5000

# Rate Limiting - Upstash
RATE_LIMIT_STORE=upstash
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth
ALLOW_INSECURE_DEV_AUTH=false
ENGINEEROS_INTERNAL_API_SECRET=your-internal-api-secret
